generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String
  password        String?
  avatarUrl       String?
  provider        String   @default("email")
  providerId      String?
  role            String   @default("user")
  authorityType   String?
  reputationScore Int      @default(0)
  totalReports    Int      @default(0)
  accurateReports Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  incidents       Incident[]
  votes           IncidentVote[]
  photos          IncidentPhoto[]
  savedRoutes     SavedRoute[]
  routeAlerts     RouteAlert[]
  notifications   Notification[]
  pushSubs        PushSubscription[]

  @@map("users")
}

model Incident {
  id            String    @id @default(uuid())
  userId        String?
  type          String
  severity      String    @default("medium")
  title         String?
  description   String?
  lat           Float
  lng           Float
  locationName  String?
  areaId        String?
  waterLevel    String?
  upvoteCount   Int       @default(0)
  downvoteCount Int       @default(0)
  isVerified    Boolean   @default(false)
  isResolved    Boolean   @default(false)
  status        String    @default("active")
  source        String    @default("user")
  expiresAt     DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  area          Area?          @relation(fields: [areaId], references: [id])
  votes         IncidentVote[]
  photos        IncidentPhoto[]

  @@map("incidents")
}

model IncidentVote {
  id          String   @id @default(uuid())
  incidentId  String
  userId      String
  voteType    String
  createdAt   DateTime @default(now())

  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([incidentId, userId])
  @@map("incident_votes")
}

model IncidentPhoto {
  id          String   @id @default(uuid())
  incidentId  String
  blobUrl     String
  thumbnailUrl String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@map("incident_photos")
}

model SavedRoute {
  id           String   @id @default(uuid())
  userId       String
  name         String
  originLat    Float
  originLng    Float
  originName   String?
  destLat      Float
  destLng      Float
  destName     String?
  usualDepart  String?
  notifyBefore Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeAlerts  RouteAlert[]

  @@map("saved_routes")
}

model RouteAlert {
  id            String   @id @default(uuid())
  userId        String
  savedRouteId  String
  alertTypes    String[]
  notifyVia     String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedRoute    SavedRoute @relation(fields: [savedRouteId], references: [id], onDelete: Cascade)

  @@map("route_alerts")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  sentVia   String[]
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  endpoint   String
  p256dhKey  String
  authKey    String
  deviceInfo Json?
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

model Area {
  id               String     @id @default(uuid())
  name             String
  zoneType         String?
  centerLat        Float?
  centerLng        Float?
  boundary         Json?
  typicalPeakHours Json?
  createdAt        DateTime   @default(now())

  incidents        Incident[]
  trafficSnapshots TrafficSnapshot[]

  @@map("areas")
}

model TrafficSnapshot {
  id            String   @id @default(uuid())
  areaId        String?
  congestion    String
  congestionPct Int?
  snapshotAt    DateTime
  dayOfWeek     Int?
  hourOfDay     Int?
  isHoliday     Boolean  @default(false)
  weather       String?
  source        String   @default("tomtom")

  area          Area?  @relation(fields: [areaId], references: [id])

  @@map("traffic_snapshots")
}

model Event {
  id           String   @id @default(uuid())
  createdBy    String?
  title        String
  description  String?
  eventType    String
  affectedArea Json?
  startsAt     DateTime
  endsAt       DateTime
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@map("events")
}

model BusRoute {
  id          String   @id @default(uuid())
  routeNumber String
  routeName   String?
  operator    String   @default("PMPML")
  color       String?
  frequency   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  stops       BusStop[]
  locations   BusLocation[]

  @@map("bus_routes")
}

model BusStop {
  id         String   @id @default(uuid())
  routeId    String
  stopName   String
  stopNumber Int?
  lat        Float
  lng        Float
  isTerminal Boolean  @default(false)
  createdAt  DateTime @default(now())

  route      BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("bus_stops")
}

model BusLocation {
  id         String   @id @default(uuid())
  routeId    String
  busId      String?
  lat        Float
  lng        Float
  speed      Float?
  heading    Float?
  recordedAt DateTime
  createdAt  DateTime @default(now())

  route      BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("bus_locations")
}
